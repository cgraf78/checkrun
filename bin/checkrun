#!/usr/bin/env bash
# checkrun — dispatch the checkrun formatter/linter compatibility commands.

set -u

_script_parent() {
  case "$1" in
    */*) printf '%s\n' "${1%/*}" ;;
    *) printf '.\n' ;;
  esac
}

_script_dir() {
  local path="$1" dir target
  while [[ -L "$path" ]]; do
    dir=$(cd -P -- "$(_script_parent "$path")" && pwd) || return 1
    target=$(readlink "$path") || return 1
    [[ "$target" == /* ]] || target="$dir/$target"
    path="$target"
  done
  cd -P -- "$(_script_parent "$path")" && pwd
}

_bin_dir=$(_script_dir "${BASH_SOURCE[0]}") || {
  echo "checkrun: cannot resolve executable path" >&2
  exit 2
}
CHECKRUN_LIB_DIR="$_bin_dir/../lib/checkrun"

# shellcheck source=../lib/checkrun/common.sh
. "$CHECKRUN_LIB_DIR/common.sh"

# Resolve once before dispatch so shell adapters and Python policy consumers
# share one cwd-independent configuration root.
CHECKRUN_CONFIG_DIR=$(_checkrun_config_dir) || exit
export CHECKRUN_CONFIG_DIR

_run_registry() {
  local python
  python=$(_checkrun_python) || {
    echo "checkrun: python3 with tomllib is required for registry planning" >&2
    exit 127
  }
  exec "$python" "$CHECKRUN_LIB_DIR/registry.py" "$@"
}

_run_schema_refresh() {
  local python
  python=$(_checkrun_python 'import sys') || {
    echo "checkrun: python3 is required for schema refresh" >&2
    exit 127
  }
  exec "$python" "$CHECKRUN_LIB_DIR/schemas/schema_refresh.py" "$@"
}

_run_verify() {
  local python
  python=$(_checkrun_python 'import sys; raise SystemExit(0 if sys.version_info >= (3, 11) else 1)') || {
    echo "checkrun: python3.11+ is required for verify checks" >&2
    exit 127
  }
  exec "$python" "$CHECKRUN_LIB_DIR/verify.py" "$@"
}

_usage() {
  cat <<'EOF'
Usage: checkrun COMMAND [ARGS...]

Commands:
  registry
            print raw Checkrun registry data
  capabilities
            print Checkrun capability metadata
  plan      emit formatter/linter execution plans
  explain   explain formatter/linter/schema policy for files
  schema    schema maintenance commands
  verify    run explicit project verification checks
  format    run autoformat compatibility entry point
  lint      run autolint compatibility entry point
  check     alias for lint
EOF
}

cmd="${1:-}"
case "$cmd" in
  registry)
    shift
    case "${1:-}" in
      --json)
        shift
        _run_registry registry --json "$@"
        ;;
      *)
        printf 'checkrun registry: expected --json\n' >&2
        exit 2
        ;;
    esac
    ;;
  capabilities)
    shift
    case "${1:-}" in
      --json | "")
        [ "${1:-}" = "--json" ] && shift
        _run_registry capabilities --json "$@"
        ;;
      *)
        printf 'checkrun capabilities: unknown option: %s\n' "$1" >&2
        exit 2
        ;;
    esac
    ;;
  plan)
    shift
    _run_registry plan "$@"
    ;;
  explain)
    shift
    _run_registry explain "$@"
    ;;
  schema)
    shift
    case "${1:-}" in
      refresh)
        shift
        _run_schema_refresh "$@"
        ;;
      -h | --help | help | "")
        cat <<'EOF'
Usage: checkrun schema COMMAND [ARGS...]

Commands:
  refresh   refresh pinned public schema payloads from association sources
EOF
        ;;
      *)
        printf 'checkrun schema: unknown command: %s\n' "$1" >&2
        exit 2
        ;;
    esac
    ;;
  verify)
    shift
    _run_verify "$@"
    ;;
  format | fmt)
    shift
    exec "$_bin_dir/autoformat" "$@"
    ;;
  lint | check)
    shift
    exec "$_bin_dir/autolint" "$@"
    ;;
  -h | --help | help | "")
    _usage
    ;;
  *)
    printf 'checkrun: unknown command: %s\n' "$cmd" >&2
    _usage >&2
    exit 2
    ;;
esac
