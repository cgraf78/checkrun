#!/usr/bin/env bash
# checkrun — dispatch the checkrun formatter/linter compatibility commands.

set -u

_script_parent() {
  case "$1" in
    */*) printf '%s\n' "${1%/*}" ;;
    *) printf '.\n' ;;
  esac
}

_script_dir() {
  local path="$1" dir target
  while [[ -L "$path" ]]; do
    dir=$(cd -P -- "$(_script_parent "$path")" && pwd) || return 1
    target=$(readlink "$path") || return 1
    [[ "$target" == /* ]] || target="$dir/$target"
    path="$target"
  done
  cd -P -- "$(_script_parent "$path")" && pwd
}

_bin_dir=$(_script_dir "${BASH_SOURCE[0]}") || {
  echo "checkrun: cannot resolve executable path" >&2
  exit 2
}

_usage() {
  cat <<'EOF'
Usage: checkrun COMMAND [ARGS...]

Commands:
  registry
            print raw Checkrun registry data
  capabilities
            print Checkrun capability metadata
  plan      emit formatter/linter execution plans
  explain   explain formatter/linter/schema policy for files
  format    run autoformat compatibility entry point
  lint      run autolint compatibility entry point
  check     alias for lint
EOF
}

cmd="${1:-}"
case "$cmd" in
  registry)
    shift
    case "${1:-}" in
      --json)
        shift
        exec "$_bin_dir/../lib/checkrun/registry.py" registry --json "$@"
        ;;
      *)
        printf 'checkrun registry: expected --json\n' >&2
        exit 2
        ;;
    esac
    ;;
  capabilities)
    shift
    case "${1:-}" in
      --json | "")
        [ "${1:-}" = "--json" ] && shift
        exec "$_bin_dir/../lib/checkrun/registry.py" capabilities --json "$@"
        ;;
      *)
        printf 'checkrun capabilities: unknown option: %s\n' "$1" >&2
        exit 2
        ;;
    esac
    ;;
  plan)
    shift
    exec "$_bin_dir/../lib/checkrun/registry.py" plan "$@"
    ;;
  explain)
    shift
    exec "$_bin_dir/../lib/checkrun/explain.py" "$@"
    ;;
  format | fmt)
    shift
    exec "$_bin_dir/autoformat" "$@"
    ;;
  lint | check)
    shift
    exec "$_bin_dir/autolint" "$@"
    ;;
  -h | --help | help | "")
    _usage
    ;;
  *)
    printf 'checkrun: unknown command: %s\n' "$cmd" >&2
    _usage >&2
    exit 2
    ;;
esac
