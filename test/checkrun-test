#!/usr/bin/env bash
# Run all repo-owned checkrun test suites.

set -euo pipefail

test_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd -P)"

for suite in "$test_dir"/suites/*-test; do
  case "${CHECKRUN_SKIP_SHELLCHECK_SUITES:-0}:${suite##*/}" in
    1:shellcheck-inventory-test | 1:shellcheck-test) continue ;;
  esac
  "$suite"
done

printf 'checkrun-test: ok\n'
