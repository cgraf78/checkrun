#!/usr/bin/env bash
# capabilities-test — verify derived Checkrun capabilities stay aligned with
# the registry contract that editor integrations consume.
#
# Usage: capabilities-test

set -o pipefail
export NO_COLOR=1

CHECKRUN_TEST_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd -P)"
CHECKRUN_REPO_ROOT="$(cd -- "$CHECKRUN_TEST_DIR/.." && pwd -P)"

# shellcheck source=../helpers.sh
. "$CHECKRUN_TEST_DIR/helpers.sh"

_require_compatible_libc "capabilities-test"

CHECKRUN="$CHECKRUN_REPO_ROOT/bin/checkrun"

echo "=== checkrun: capability metadata ==="

output=$("$CHECKRUN" capabilities --json 2>&1)
rc=$?
_assert_exit "capabilities: command exits 0" 0 "$rc"

printf '%s\n' "$output" | python3 -c '
import json
import sys

data = json.load(sys.stdin)
filetypes = data["filetypes"]

assert data["version"] == 2
assert "sley" not in data
assert "python" in filetypes["format"]
assert "systemd" in filetypes["lint"]
assert "text" in filetypes["lint"]
assert "c" in filetypes["format"]
assert "c" in filetypes["lint"]
assert filetypes["custom"]["filename"]["Dockerfile"] == "dockerfile"
assert filetypes["custom"]["filename"]["CMakeLists.txt"] == "cmake"
assert filetypes["custom"]["extension"]["service"] == "systemd"

patterns = filetypes["custom"]["patterns"]
assert any(item["pattern"] == "agent-hook-*" and item["filetype"] == "sh" for item in patterns)
assert patterns == sorted(patterns, key=lambda item: item["pattern"])
assert filetypes["format"] == sorted(filetypes["format"])
assert filetypes["lint"] == sorted(filetypes["lint"])
'
_assert_exit "capabilities: emits generic registry-derived metadata" 0 "$?"

output=$("$CHECKRUN" registry --json 2>&1)
rc=$?
_assert_exit "registry: command exits 0" 0 "$rc"

printf '%s\n' "$output" | python3 -c '
import json
import sys

data = json.load(sys.stdin)
selectors = {item["id"]: item for item in data["selectors"]}
assert data["version"] == 1
assert "sley" not in data
assert selectors["c-family"].get("lint", []) == []
assert [item["tool"] for item in selectors["yaml"]["lint"]] == ["actionlint", "zizmor"]
'
_assert_exit "registry: emits raw registry data" 0 "$?"

_test_summary
