import importlib.util
import sys
from pathlib import Path

script, policy_arg, fifo_arg = sys.argv[1:]
script_path = Path(script)
policy_path = Path(policy_arg)
fifo_path = Path(fifo_arg)
sys.path.insert(0, str(script_path.parent))
spec = importlib.util.spec_from_file_location("schema_lint", script_path)
module = importlib.util.module_from_spec(spec)
sys.modules[spec.name] = module
spec.loader.exec_module(module)

original_is_file = Path.is_file
swapped = False


def raced_is_file(path):
    global swapped
    result = original_is_file(path)
    if not swapped and path == policy_path and result:
        policy_path.unlink()
        policy_path.symlink_to(fifo_path)
        swapped = True
    return result


Path.is_file = raced_is_file
module.schema_policy.policy_path = lambda: policy_path
raise SystemExit(module._run([str(policy_path)], json_output=False))
PY
)
