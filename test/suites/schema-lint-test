#!/usr/bin/env bash
# schema-lint-test — unit tests for shared Checkrun schema validation.
#
# Usage: schema-lint-test

set -o pipefail
export NO_COLOR=1

CHECKRUN_TEST_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd -P)"
CHECKRUN_REPO_ROOT="$(cd -- "$CHECKRUN_TEST_DIR/.." && pwd -P)"

# shellcheck source=../helpers.sh
. "$CHECKRUN_TEST_DIR/helpers.sh"

_require_compatible_libc "schema-lint-test"

SCRIPT="$CHECKRUN_REPO_ROOT/lib/checkrun/schemas/schema-lint.py"
POLICY_SCRIPT="$CHECKRUN_REPO_ROOT/lib/checkrun/schemas/schema_policy.py"
POLICY_SCHEMA="$CHECKRUN_REPO_ROOT/share/checkrun/schemas/associations.schema.json"

echo "=== schema-lint: public schema API ==="

_assert_file_exists "policy schema: repo schema file is tracked" "$POLICY_SCHEMA"
python3 - "$POLICY_SCHEMA" "$CHECKRUN_REPO_ROOT/lib/checkrun/schemas" <<'PY'
import json
import sys

schema_path, module_dir = sys.argv[1:]
sys.path.insert(0, module_dir)
import schema_policy  # noqa: E402

with open(schema_path, encoding="utf-8") as handle:
    schema = json.load(handle)

association = schema["properties"]["associations"]["items"]
assert schema_policy._POLICY_FIELDS == frozenset(schema["properties"])
assert schema_policy._POLICY_REQUIRED == frozenset(schema["required"])
assert schema_policy._ASSOCIATION_FIELDS == frozenset(association["properties"])
assert schema_policy._ASSOCIATION_REQUIRED == frozenset(association["required"])
assert schema_policy._FORMATS == frozenset(association["properties"]["format"]["enum"])
PY
_assert_exit "policy schema: runtime shape constants match canonical schema" 0 "$?"

_schema_python=(python3)
if ! python3 -c 'import jsonschema' 2>/dev/null; then
  if command -v uv >/dev/null 2>&1; then
    _schema_python=(uv run --quiet --with jsonschema python)
  else
    _schema_python=()
  fi
fi
if [[ "${#_schema_python[@]}" -gt 0 ]]; then
  "${_schema_python[@]}" - "$POLICY_SCHEMA" "$CHECKRUN_REPO_ROOT/lib/checkrun/schemas" <<'PY'
import copy
import json
import sys

import jsonschema

schema_path, module_dir = sys.argv[1:]
sys.path.insert(0, module_dir)
import schema_policy  # noqa: E402

with open(schema_path, encoding="utf-8") as handle:
    schema = json.load(handle)

validator_cls = jsonschema.validators.validator_for(schema)
validator_cls.check_schema(schema)
validator = validator_cls(schema)
base = {
    "version": 1,
    "schemaDataDir": "schemas",
    "associations": [
        {
            "name": "Example",
            "format": "json",
            "schema": "example.schema.json",
            "dependency": "owner/repo",
            "source": "https://example.invalid/schema.json",
            "editorSource": "https://example.invalid/editor-schema.json",
            "matches": ["**/example.json"],
            "enforce": True,
            "note": "Example association",
        }
    ],
}

assert not list(validator.iter_errors(base))
schema_policy.validate_policy(copy.deepcopy(base))

mutations = {
    "schemaDataDir": ("schemaDataDir",),
    "name": ("associations", 0, "name"),
    "schema": ("associations", 0, "schema"),
    "dependency": ("associations", 0, "dependency"),
    "source": ("associations", 0, "source"),
    "editorSource": ("associations", 0, "editorSource"),
    "matches": ("associations", 0, "matches", 0),
    "note": ("associations", 0, "note"),
}

for field, location in mutations.items():
    policy = copy.deepcopy(base)
    parent = policy
    for component in location[:-1]:
        parent = parent[component]
    parent[location[-1]] += "\n"
    schema_rejected = bool(list(validator.iter_errors(policy)))
    try:
        schema_policy.validate_policy(policy)
    except schema_policy.SchemaPolicyError:
        runtime_rejected = True
    else:
        runtime_rejected = False
    assert schema_rejected, f"JSON Schema accepted trailing newline in {field}"
    assert runtime_rejected, f"runtime accepted trailing newline in {field}"
PY
  _assert_exit "policy schema: control-character mutations match runtime behavior" 0 "$?"
else
  echo "  SKIP: policy schema behavioral parity (jsonschema and uv unavailable)"
fi

echo "=== schema-lint: policy matching and diagnostics ==="

