python3 - "$POLICY_SCRIPT" <<'PY'
import importlib.util
import sys
from pathlib import Path

script = Path(sys.argv[1])
spec = importlib.util.spec_from_file_location("checkrun_schema_policy", script)
module = importlib.util.module_from_spec(spec)
assert spec.loader is not None
spec.loader.exec_module(module)

assert module.__all__ == [
    "PathPolicyError",
    "SchemaPolicyError",
    "load_json",
    "load_policy",
    "validate_policy",
    "policy_path",
    "policy_schema_path",
    "schema_path",
    "schema_url",
    "matching_associations",
    "lsp_schema_config",
]
assert hasattr(module, "lsp_schema_config")
assert not hasattr(module, "nvim_config")
PY
_assert_exit "policy API: public facade is explicit" 0 "$?"

