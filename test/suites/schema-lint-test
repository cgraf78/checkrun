import errno
import importlib.util
import sys
from pathlib import Path
from unittest import mock

script, policy_arg = sys.argv[1:]
script_path = Path(script)
policy_path = Path(policy_arg)
sys.path.insert(0, str(script_path.parent))
spec = importlib.util.spec_from_file_location("schema_policy", script_path)
module = importlib.util.module_from_spec(spec)
sys.modules[spec.name] = module
spec.loader.exec_module(module)

denied = PermissionError(errno.EACCES, "Permission denied", str(policy_path))
with mock.patch.object(module.os, "open", side_effect=denied):
    try:
        module._load_policy_document(policy_path)
    except module.SchemaPolicyError as exc:
        message = str(exc)
        assert f"cannot read schema policy {policy_path}" in message
        assert "Permission denied" in message
    else:
        raise AssertionError("PermissionError did not fail closed")
PY
