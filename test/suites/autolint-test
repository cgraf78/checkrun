# golangci-lint (Go)
if command -v golangci-lint &>/dev/null && command -v go &>/dev/null; then
  _json_go_dir=$(_tmpdir)
  cat >"$_json_go_dir/go.mod" <<'EOF'
module example.com/test
go 1.21
EOF
  cat >"$_json_go_dir/bad.go" <<'EOF'
package main
import "fmt"
func main() {
	x := 1
	fmt.Println("hello")
}
EOF
  set +e
  output=$("$AUTOLINT" --json "$_json_go_dir/bad.go" 2>/dev/null)
  rc=$?
  set -e
  if [ "$rc" -ne 0 ] && [ -n "$output" ]; then
    _assert_json_lines_valid "json go: valid unified schema" "$output" "golangci-lint"
  else
    echo "  SKIP: json go (golangci-lint did not flag test fixture)"
  fi
fi

# clippy (Rust)
_json_rust_mock=$(_mock_bin)
cat >"$_json_rust_mock/cargo" <<'EOF'
#!/usr/bin/env bash
if [ "$1" = "clippy" ] && [ "${2:-}" = "--version" ]; then
  exit 0
fi
case "$*" in
  *"--message-format=json"*)
    printf '%s\n' '{"reason":"compiler-message","message":{"level":"warning","message":"manual implementation of unwrap_or","code":{"code":"clippy::manual_unwrap_or"},"spans":[{"file_name":"src/lib.rs","is_primary":true,"line_start":1,"column_start":1,"line_end":1,"column_end":3}]}}'
    exit 1
    ;;
  *)
    exit 0
    ;;
esac
EOF
chmod +x "$_json_rust_mock/cargo"
_json_rust_dir=$(_tmpdir)
cat >"$_json_rust_dir/Cargo.toml" <<'EOF'
[package]
name = "jsonlinttest"
version = "0.1.0"
edition = "2021"
EOF
mkdir -p "$_json_rust_dir/src"
cat >"$_json_rust_dir/src/lib.rs" <<'EOF'
pub fn f() {}
EOF
set +e
output=$(PATH="$_json_rust_mock:$PATH" "$AUTOLINT" --json "$_json_rust_dir/src/lib.rs" 2>/dev/null)
rc=$?
set -e
_assert_exit "json rust: exits non-zero on clippy finding" 1 "$rc"
_assert_json_lines_valid "json rust: valid unified schema" "$output" "clippy"
_assert_contains "json rust: clippy code present" '"code":"clippy::manual_unwrap_or"' "$output"

# typos
_json_typos_mock=$(_mock_bin)
cat >"$_json_typos_mock/typos" <<'EOF'
#!/usr/bin/env bash
last="${@: -1}"
case "$*" in
  *"--format json"*)
    printf '{"type":"typo","path":"%s","line_num":1,"byte_offset":19,"typo":"zzword","corrections":["realword"]}\n' "$last"
    exit 2
    ;;
  *)
    exit 0
    ;;
esac
EOF
chmod +x "$_json_typos_mock/typos"

cat >"$_td/json-typo.txt" <<'EOF'
This sentence has zzword.
EOF
set +e
output=$(PATH="$_json_typos_mock:$PATH" CHECKRUN_AUTOLINT_DIR=/nonexistent "$AUTOLINT" --json "$_td/json-typo.txt" 2>/dev/null)
rc=$?
set -e
_assert_exit "json typos: exits non-zero" 2 "$rc"
_assert_json_lines_valid "json typos: valid unified schema" "$output" "typos"
_assert_contains "json typos: typo code present" '"code":"zzword"' "$output"

_json_checkmake_mock=$(_mock_bin)
cat >"$_json_checkmake_mock/checkmake" <<'EOF'
#!/usr/bin/env bash
last="${@: -1}"
cat <<JSON
[
  {
    "rule": "minphony",
    "violation": "missing .PHONY target",
    "file_name": "$last",
    "line_number": 1
  }
]
JSON
exit 6
EOF
chmod +x "$_json_checkmake_mock/checkmake"

_json_make_dir=$(_tmpdir)
cat >"$_json_make_dir/Makefile" <<'EOF'
all:
	echo hi
EOF
set +e
output=$(PATH="$_json_checkmake_mock:$PATH" "$AUTOLINT" --json "$_json_make_dir/Makefile" 2>/dev/null)
rc=$?
set -e
_assert_exit "json make: exits non-zero" 6 "$rc"
_assert_json_lines_valid "json make: valid unified schema" "$output" "checkmake"
_assert_contains "json make: checkmake message present" "missing .PHONY target" "$output"

# Clean input → no output in json mode, exit 0.
cat >"$_td/json-ok.py" <<'EOF'
x = 1
EOF
set +e
output=$("$AUTOLINT" --json "$_td/json-ok.py" 2>/dev/null)
rc=$?
set -e
_assert_exit "json py: exits 0 on clean file" 0 "$rc"
_assert_eq "json py: no output on clean file" "" "$output"

# Missing jq → hard error (same shape as missing yq).
_nojq_bin=$(_mock_bin)
ln -s "$(command -v bash)" "$_nojq_bin/bash"
ln -s "$(command -v yq)" "$_nojq_bin/yq"
set +e
output=$(PATH="$_nojq_bin" "$AUTOLINT" --json "$_td/json-ok.py" 2>&1)
rc=$?
set -e
_assert_exit "json: missing jq exits 1" 1 "$rc"
_assert_contains "json: missing jq error message" "jq is required for --json" "$output"

