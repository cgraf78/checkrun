_assert_contains_path_arg "toml: fallback taplo.toml passed via --config" \
  "--config " "$_alt_taplo/taplo.toml" "$output"

# No per-repo config + no fallback → --no-schema.
echo 'k = "v"' >"$_td/ns.toml"
set +e
output=$(CHECKRUN_AUTOLINT_DIR=/nonexistent PATH="$_taplo_mockbin:$PATH" "$AUTOLINT" "$_td/ns.toml" 2>&1)
rc=$?
set -e
_assert_exit "toml: no configs → exits 0" 0 "$rc"
_assert_contains "toml: no configs → --no-schema" "--no-schema" "$output"

# Dispatch-wiring: selene config routing. Selene only looks for its
# config in cwd, not the file's parent chain. Autolint uses _find_config
# to locate selene.toml in the parent chain and passes --config explicitly.
_selene_mockbin=$(_mock_bin)
cat >"$_selene_mockbin/selene" <<'EOF'
#!/usr/bin/env bash
echo "MOCK-SELENE-ARGS: $*"
exit 0
EOF
chmod +x "$_selene_mockbin/selene"

# Per-repo selene.toml in parent dir → passed via --config.
_selene_parent=$(_tmpdir)
mkdir -p "$_selene_parent/sub"
: >"$_selene_parent/selene.toml"
echo 'print("hi")' >"$_selene_parent/sub/test.lua"
