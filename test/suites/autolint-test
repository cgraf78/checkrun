_assert_exit "lua: parent selene.toml — exits 0" 0 "$rc"
_assert_contains_path_arg "lua: parent selene.toml passed via --config" \
  "--config " "$_selene_parent/selene.toml" "$output"

# No per-repo config + $CHECKRUN_AUTOLINT_DIR/selene.toml present → fallback applies.
_alt_selene=$(_tmpdir)
: >"$_alt_selene/selene.toml"
echo 'print("hi")' >"$_td/fb.lua"
set +e
output=$(CHECKRUN_AUTOLINT_DIR="$_alt_selene" PATH="$_selene_mockbin:$PATH" "$AUTOLINT" "$_td/fb.lua" 2>&1)
