  output=$("$AUTOLINT" "$_td/unused.lua" 2>&1)
  rc=$?
  set -e
  _assert_exit "lua: fallback config flags unused locals" 1 "$rc"
  _assert_contains "lua: unused local diagnostic shown" "unused_variable" "$output"
fi

