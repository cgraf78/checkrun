set -e
_assert_exit "lua: fallback selene.toml — exits 0" 0 "$rc"
_assert_contains_path_arg "lua: fallback selene.toml passed via --config" \
  "--config " "$_alt_selene/selene.toml" "$output"

# No per-repo config + no fallback → no --config arg.
echo 'print("hi")' >"$_td/nc.lua"
set +e
output=$(CHECKRUN_AUTOLINT_DIR=/nonexistent PATH="$_selene_mockbin:$PATH" "$AUTOLINT" "$_td/nc.lua" 2>&1)
rc=$?
set -e
_assert_exit "lua: no configs → exits 0" 0 "$rc"
_assert_not_contains "lua: no configs → no --config" "--config" "$output"

