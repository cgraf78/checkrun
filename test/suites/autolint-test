# ---------------------------------------------------------------------------
# Tests: --json mode — unified schema per tool
#
# Each subtest feeds a known-bad fixture and asserts the per-tool
# output is a stream of JSON objects matching the unified schema:
#   {path, line, col, severity, message, source} (+ optional
#   code/end_line/end_col). Position fields must be 1-based integers.
# These tests pin the schema so tool-version drift fails loudly
# rather than silently reshaping the diagnostics nvim consumes.
# ---------------------------------------------------------------------------

echo "=== --json: unified schema per filetype ==="

# Shared assertion: every non-empty line of $1 parses as JSON with
# the required fields and sensible types/values.
_assert_json_lines_valid() {
  local label="$1" output="$2" expected_source="$3"
  if [ -z "$output" ]; then
    _fail "$label (no output)"
    return
  fi
  local check
  # Walk each input record and return the first schema problem we
  # find, or "ok" if every record is well-formed. `inputs` + `-n`
  # streams JSON-lines safely even when a record contains nested
  # objects that span no newlines.
  check=$(printf '%s\n' "$output" | jq -nr --arg src "$expected_source" '
    def problem:
      if type != "object" then "not-object"
      elif (.path | type) != "string" then "bad-path"
      elif (.line | type) != "number" or .line < 1 then "bad-line"
      elif (.col  | type) != "number" or .col  < 1 then "bad-col"
      elif ([.severity] | inside(["error","warning","info","hint"]) | not) then "bad-severity: " + (.severity|tostring)
      elif (.message | type) != "string" or (.message | length) == 0 then "bad-message"
      elif .source != $src then "bad-source: " + (.source|tostring)
      else "ok"
      end;
    [inputs | problem] as $ps |
    if ($ps | length) == 0 then "no-records"
    else ($ps | map(select(. != "ok")) | if length == 0 then "ok" else .[0] end)
    end')
  if [ "$check" = "ok" ]; then
    _pass "$label"
  else
    _fail "$label ($check)"
  fi
}

