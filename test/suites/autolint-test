FROM ubuntu
RUN apt-get update && apt-get install -y python
EOF
  # Rename to Dockerfile for basename dispatch
  mv "$_td/json-Dockerfile" "$_td/Dockerfile.json-test"
  set +e
  output=$("$AUTOLINT" --json "$_td/Dockerfile.json-test" 2>/dev/null)
  rc=$?
  set -e
  _assert_exit "json dockerfile: exits non-zero" 1 "$rc"
  _assert_json_lines_valid "json dockerfile: valid unified schema" "$output" "hadolint"
  _assert_contains "json dockerfile: hadolint code present" '"code":"DL' "$output"
fi

# buildifier (Starlark .bzl)
if command -v buildifier &>/dev/null; then
  cat >"$_td/json-bad.bzl" <<'EOF'
def _impl(ctx):
  pass
my_rule = rule(implementation = _impl)
EOF
  set +e
  output=$("$AUTOLINT" --json "$_td/json-bad.bzl" 2>/dev/null)
  rc=$?
  set -e
  # buildifier may or may not produce warnings on this fixture;
  # if it does, verify the schema is correct.
  if [ -n "$output" ]; then
    _assert_json_lines_valid "json bzl: valid unified schema" "$output" "buildifier"
  else
    _pass "json bzl: no warnings (clean fixture)"
  fi
fi

# superhtml (HTML)
if command -v superhtml &>/dev/null; then
  cat >"$_td/json-bad.html" <<'EOF'
