#!/usr/bin/env bash
# autolint-test — unit tests for the autolint script.
#
# Tests linting dispatch, error detection, auto-fix, shebang detection,
# and no-op behavior for unsupported/missing files.
#
# Usage: autolint-test

set -o pipefail
export NO_COLOR=1

# Formatter/linter dev tooling is expected to come from a mise toolset, so seed
# the shim dir explicitly for direct test runs. CI sets MISE_GLOBAL_CONFIG_FILE
# to the repo-local manifest; local runs usually inherit the user's superset.
# On macOS, brew binaries are signed and must take priority over
# unsigned mise downloads that macOS Gatekeeper kills.
[ -d "$HOME/.local/share/mise/shims" ] &&
  PATH="$HOME/.local/share/mise/shims:$PATH"
[ -d "/opt/homebrew/bin" ] &&
  PATH="/opt/homebrew/bin:$PATH"
: "${MISE_GLOBAL_CONFIG_FILE:=$HOME/.config/mise/config.toml}"
export MISE_GLOBAL_CONFIG_FILE

CHECKRUN_TEST_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd -P)"
CHECKRUN_TEST_ROOT="$(cd -- "$CHECKRUN_TEST_DIR/.." && pwd -P)"

# shellcheck source=../helpers.sh
. "$CHECKRUN_TEST_DIR/helpers.sh"

_require_compatible_libc "autolint-test"

AUTOLINT="$CHECKRUN_TEST_ROOT/bin/autolint"
export CHECKRUN_AUTOLINT_DIR
CHECKRUN_AUTOLINT_DIR=$(_checkrun_default_autoformat_dir)

# ---------------------------------------------------------------------------
# Tests: CLI help
# ---------------------------------------------------------------------------

echo "=== CLI help ==="

set +e
output=$("$AUTOLINT" --help 2>&1)
rc=$?
_assert_exit "help: --help exits 0" 0 "$rc"
_assert_contains "help: --help shows usage" "Usage: autolint" "$output"
_assert_contains "help: --help lists supported file types" "Supported file types:" "$output"
_assert_colon_list_values_aligned "help: --help aligns supported file list" \
  "$output" "Supported file types:"
_assert_contains "help: --help aligns build category" "Build:     .bzl" "$output"
_assert_contains "help: --help lists make files" "Makefile, GNUmakefile, .mk" "$output"
_assert_contains "help: --help lists cmake files" "CMakeLists.txt, .cmake" "$output"
_assert_contains "help: --help aligns ci category" "CI:        .github/workflows" "$output"
_assert_contains "help: --help aligns container category" "Container: Dockerfile" "$output"
_assert_contains "help: --help uses docs/text category" "Docs/text: .md" "$output"
_assert_contains "help: --help lists shell files" ".sh, .bash, .zsh" "$output"
_assert_contains "help: --help lists systemd units" ".service" "$output"
_assert_contains "help: --help lists systemd timers" ".timer" "$output"
_assert_contains "help: --help lists systemd sockets" ".socket" "$output"
_assert_contains "help: --help lists envrc files" ".envrc" "$output"
_assert_contains "help: --help lists java files" ".java" "$output"
_assert_contains "help: --help lists php files" ".php" "$output"
_assert_contains "help: --help lists ruby files" ".rb" "$output"
_assert_contains "help: --help lists json files" ".json, .jsonc" "$output"
_assert_contains "help: --help lists css files" ".css" "$output"
_assert_contains "help: --help lists config linters" ".editorconfig, .toml, git config, tmux.conf, crontab" "$output"
_assert_contains "help: --help lists workflow files" ".github/workflows/*.yml" "$output"
_assert_contains "help: --help lists docker files" "Dockerfile, Containerfile" "$output"
_assert_not_contains "help: --help has no other bucket" "Other:" "$output"

set +e
output=$("$AUTOLINT" -h 2>&1)
rc=$?
_assert_exit "help: -h exits 0" 0 "$rc"
_assert_contains "help: -h shows usage" "Usage: autolint" "$output"
_assert_contains "help: -h lists supported file types" "Supported file types:" "$output"
_assert_not_contains "help: -h has no other bucket" "Other:" "$output"

symlink_bin=$(_tmpdir)/bin
mkdir -p "$symlink_bin"
ln -s "$AUTOLINT" "$symlink_bin/autolint"

set +e
output=$("$symlink_bin/autolint" --help 2>&1)
rc=$?
_assert_exit "help: symlinked autolint resolves dependency library" 0 "$rc"
_assert_contains "help: symlinked autolint shows usage" "Usage: autolint" "$output"

# ---------------------------------------------------------------------------
# Tests: linter module wiring
# ---------------------------------------------------------------------------

echo "=== Linter module wiring ==="

_autolint_impl="$CHECKRUN_TEST_ROOT/lib/checkrun/autolint.sh"
_linter_dir="$CHECKRUN_TEST_ROOT/lib/checkrun/linters"

_linter_sources=$(
  awk -v root="$CHECKRUN_TEST_ROOT/lib/checkrun" '
    /^\.[[:space:]]+"\$CHECKRUN_LIB_DIR\/linters\/.*\.sh"$/ {
      path = $2
      gsub(/^"/, "", path)
      gsub(/"$/, "", path)
      sub(/^\$CHECKRUN_LIB_DIR/, root, path)
      print path
    }
  ' "$_autolint_impl"
)
_sorted_linter_sources=$(printf '%s\n' "$_linter_sources" | sort)
_expected_linter_sources=$(find "$_linter_dir" -type f -name '*.sh' -print | sort)
_first_linter_source=$(printf '%s\n' "$_linter_sources" | sed -n '1p')

_assert_eq "linter sources: every adapter file is loaded" \
  "$_expected_linter_sources" "$_sorted_linter_sources"
_assert_eq "linter sources: shared core loads before adapters" \
  "$_linter_dir/core.sh" "$_first_linter_source"

set +e
output=$(bash -c '. "$1"; _autolint_merge_rc "$2" "$3"' _ "$_autolint_impl" 1 125)
rc=$?
set -e
_assert_exit "exit merge: unknown adapter sentinel is preserved" 0 "$rc"
_assert_eq "exit merge: 125 dominates lint findings" "125" "$output"

set +e
output=$(bash -c '. "$1"; _autolint_merge_rc "$2" "$3"' _ "$_autolint_impl" 125 1)
rc=$?
set -e
_assert_exit "exit merge: prior sentinel is preserved" 0 "$rc"
_assert_eq "exit merge: prior 125 dominates lint findings" "125" "$output"

set +e
output=$(bash -c '. "$1"; _autolint_merge_rc "$2" "$3"' _ "$_autolint_impl" 1 2)
rc=$?
set -e
_assert_exit "exit merge: registry errors are preserved" 0 "$rc"
_assert_eq "exit merge: 2 dominates lint findings" "2" "$output"

