# ---------------------------------------------------------------------------
# Tests: multi-file linting runs concurrently
# ---------------------------------------------------------------------------

echo "=== Multi-file concurrency ==="

_parallel_dir=$(_tmpdir)
_parallel_sync=$(_tmpdir)
cat >"$_parallel_dir/a.sh" <<'EOF'
#!/usr/bin/env bash
echo "a"
EOF
cat >"$_parallel_dir/b.sh" <<'EOF'
#!/usr/bin/env bash
echo "b"
EOF

_parallel_mock=$(_mock_bin)
cat >"$_parallel_mock/yq" <<'EOF'
#!/usr/bin/env bash
exit 0
EOF
cat >"$_parallel_mock/shellcheck" <<'EOF'
#!/usr/bin/env bash
file="${@: -1}"
case "${file##*/}" in
  a.sh)
    touch "$AUTOLINT_PARALLEL_SYNC/a-start"
    for _i in $(seq 1 100); do
      if [ -f "$AUTOLINT_PARALLEL_SYNC/b-start" ]; then
        echo "a saw b"
        exit 0
      fi
      sleep 0.02
    done
    echo "a timed out waiting for b" >&2
    exit 7
    ;;
  b.sh)
    touch "$AUTOLINT_PARALLEL_SYNC/b-start"
    echo "b started"
    exit 0
    ;;
esac
EOF
chmod +x "$_parallel_mock/yq" "$_parallel_mock/shellcheck"

set +e
output=$(CHECKRUN_AUTOLINT_DIR=/nonexistent AUTOLINT_PARALLEL_SYNC="$_parallel_sync" \
  PATH="$_parallel_mock:$PATH" "$AUTOLINT" "$_parallel_dir/a.sh" "$_parallel_dir/b.sh" 2>&1)
rc=$?
set -e
_assert_exit "parallel: second file starts before first completes" 0 "$rc"
_assert_contains "parallel: first file observes second" "a saw b" "$output"
_assert_eq "parallel: output preserves input order" $'a saw b\nb started' "$output"

# The batch runner forks worker subshells. Adapters intentionally read
# `_autolint_main`'s local `json` flag via Bash dynamic scope, so this pins the
# non-obvious contract that `--json` still reaches parallel workers.
_parallel_json_dir=$(_tmpdir)
_parallel_json_sync=$(_tmpdir)
cat >"$_parallel_json_dir/a.sh" <<'EOF'
#!/usr/bin/env bash
echo "$A"
EOF
cat >"$_parallel_json_dir/b.sh" <<'EOF'
#!/usr/bin/env bash
echo "$B"
EOF

_parallel_json_mock=$(_mock_bin)
cat >"$_parallel_json_mock/yq" <<'EOF'
#!/usr/bin/env bash
exit 0
EOF
cat >"$_parallel_json_mock/shellcheck" <<'EOF'
#!/usr/bin/env bash
format=
prev=
for arg in "$@"; do
  if [ "$prev" = "-f" ]; then
    format=$arg
    break
  fi
  prev=$arg
done
[ "$format" = "json1" ] || {
  echo "expected shellcheck -f json1, got: $*" >&2
  exit 9
}

file="${@: -1}"
case "${file##*/}" in
  a.sh)
    touch "$AUTOLINT_PARALLEL_JSON_SYNC/a-start"
    saw_b=0
    for _i in $(seq 1 100); do
      if [ -f "$AUTOLINT_PARALLEL_JSON_SYNC/b-start" ]; then
        saw_b=1
        break
      fi
      sleep 0.02
    done
    if [ "$saw_b" -ne 1 ]; then
      echo "a timed out waiting for b" >&2
      exit 7
    fi
    ;;
  b.sh)
    touch "$AUTOLINT_PARALLEL_JSON_SYNC/b-start"
    ;;
esac

printf '{"comments":[{"line":1,"column":1,"endLine":1,"endColumn":8,"level":"error","code":2086,"message":"mock finding in %s"}]}\n' "${file##*/}"
exit 1
EOF
chmod +x "$_parallel_json_mock/yq" "$_parallel_json_mock/shellcheck"

set +e
output=$(CHECKRUN_AUTOLINT_DIR=/nonexistent CHECKRUN_AUTOLINT_JOBS=2 \
  AUTOLINT_PARALLEL_JSON_SYNC="$_parallel_json_sync" \
  PATH="$_parallel_json_mock:$PATH" \
  "$AUTOLINT" --json "$_parallel_json_dir/a.sh" "$_parallel_json_dir/b.sh" 2>&1)
rc=$?
set -e
_assert_exit "parallel json: exits non-zero on findings" 1 "$rc"
_parallel_json_check=$(printf '%s\n' "$output" | jq -e -s '
  length == 2 and
  (.[0].path | endswith("/a.sh")) and
  (.[1].path | endswith("/b.sh")) and
  all(.[]; .source == "shellcheck" and .code == "SC2086")
' >/dev/null && echo ok || echo fail)
_assert_eq "parallel json: workers inherit json mode and preserve order" \
  "ok" "$_parallel_json_check"

# Schema validation is policy-driven and cross-cutting: fixture JSON
# and YAML names should be checked before extension dispatch decides which
# language linter, if any, also applies.
if python3 - <<'PY' >/dev/null 2>&1; then
import jsonschema
import yaml
PY
  _schema_td=$(_tmpdir)
  _schema_dir="$_schema_td/copy/.config/example/schema.d"
  mkdir -p "$_schema_dir" "$_schema_td/schemas"
  cat >"$_schema_td/schemas/settings.schema.json" <<'JSON'
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["enabled"],
  "additionalProperties": false,
  "properties": {
    "enabled": { "type": "boolean" }
  }
}
JSON
  cat >"$_schema_td/associations.json" <<JSON
{
  "version": 1,
  "schemaDataDir": "$_schema_td/schemas",
  "associations": [
    {
      "name": "Test settings",
      "format": "json",
      "schema": "settings.schema.json",
      "matches": [".config/example/schema.d/test-settings-*.json"],
      "enforce": true
    },
    {
      "name": "Advisory settings",
      "format": "json",
      "schema": "settings.schema.json",
      "matches": [".config/example/schema.d/advisory-settings-*.json"],
      "enforce": false
    }
  ]
}
JSON
  cat >"$_schema_dir/test-settings-bad.json" <<'JSON'
{ "enabled": "yes" }
JSON
  cat >"$_schema_dir/advisory-settings-bad.json" <<'JSON'
{ "enabled": "yes" }
JSON

  set +e
  output=$(CHECKRUN_SCHEMA_ASSOCIATIONS="$_schema_td/associations.json" "$AUTOLINT" "$_schema_dir/test-settings-bad.json" 2>&1)
  rc=$?
  set -e
  _assert_exit "schema: enforced association exits non-zero" 1 "$rc"
  _assert_contains "schema: enforced association reports schema name" "Test settings" "$output"

  set +e
  output=$(CHECKRUN_SCHEMA_ASSOCIATIONS="$_schema_td/associations.json" "$AUTOLINT" "$_schema_dir/advisory-settings-bad.json" 2>&1)
  rc=$?
  set -e
  _assert_exit "schema: advisory association does not fail autolint" 0 "$rc"

  set +e
  output=$(CHECKRUN_SCHEMA_ASSOCIATIONS="$_schema_td/associations.json" "$AUTOLINT" --json "$_schema_dir/test-settings-bad.json" 2>/dev/null)
  rc=$?
  set -e
  _assert_exit "schema json: enforced association exits non-zero" 1 "$rc"
  if printf '%s\n' "$output" | jq -e '
    select(
      .source == "json-schema" and
      .code == "Test settings" and
      (.line | type == "number") and
      (.col | type == "number") and
      (.message | contains("enabled"))
    )
  ' >/dev/null; then
    _pass "schema json: valid unified schema"
  else
    _fail "schema json: valid unified schema"
  fi
  _assert_contains "schema json: code carries association name" '"code":"Test settings"' "$output"
else
  echo "  SKIP: schema validation (requires python jsonschema and PyYAML)"
fi

