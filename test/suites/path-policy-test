#!/usr/bin/env bash
# path-policy-test — user config/data directory precedence across shell and Python.

set -o pipefail
export NO_COLOR=1

CHECKRUN_TEST_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd -P)"
CHECKRUN_REPO_ROOT="$(cd -- "$CHECKRUN_TEST_DIR/.." && pwd -P)"
export CHECKRUN_LIB_DIR="$CHECKRUN_REPO_ROOT/lib/checkrun"

# shellcheck source=../helpers.sh
. "$CHECKRUN_TEST_DIR/helpers.sh"

echo "=== checkrun: XDG path policy ==="

_td=$(_tmpdir)
_home="$_td/home"
_xdg_config="$_td/config root"
_xdg_data="$_td/data root"
mkdir -p "$_home" "$_xdg_config" "$_xdg_data"

output=$(HOME="$_home" XDG_CONFIG_HOME="$_xdg_config" CHECKRUN_CONFIG_DIR='' \
  bash -c '. "$1"; _checkrun_config_dir' bash "$CHECKRUN_REPO_ROOT/lib/checkrun/common.sh")
_assert_eq "shell config: absolute XDG_CONFIG_HOME is honored" \
  "$_xdg_config/checkrun" "$output"

# shellcheck disable=SC2016 # $1 expands inside the isolated shell.
output=$(env -u HOME XDG_CONFIG_HOME="$_xdg_config" CHECKRUN_CONFIG_DIR='' \
  bash -c '. "$1"; _checkrun_config_dir' bash "$CHECKRUN_REPO_ROOT/lib/checkrun/common.sh")
_assert_eq "shell config: absolute XDG_CONFIG_HOME does not require HOME" \
  "$_xdg_config/checkrun" "$output"

output=$(HOME="$_home" XDG_CONFIG_HOME=relative/config CHECKRUN_CONFIG_DIR='' \
  bash -c '. "$1"; _checkrun_config_dir' bash "$CHECKRUN_REPO_ROOT/lib/checkrun/common.sh")
_assert_eq "shell config: relative XDG_CONFIG_HOME is ignored" \
  "$_home/.config/checkrun" "$output"

mkdir -p "$_td/launch/explicit config"
# Python resolves explicit overrides to filesystem identity. On macOS, temp
# paths may therefore change from the visible `/var` spelling to `/private/var`.
output=$(cd "$_td/launch" && HOME="$_home" XDG_CONFIG_HOME="$_xdg_config" \
  CHECKRUN_CONFIG_DIR='explicit config' \
  bash -c '. "$1"; _checkrun_config_dir' bash "$CHECKRUN_REPO_ROOT/lib/checkrun/common.sh")
_assert_eq "shell config: explicit relative override wins and becomes cwd-independent" \
  "$(_canonical_test_path "$_td/launch/explicit config")" "$output"

mkdir -p "$_home/real" "$_td/env root/nested" "$_td/launch/\$HOME/real"
output=$(cd "$_td/launch" && HOME="$_home" CHECKRUN_CONFIG_DIR='$HOME/real' \
  bash -c '. "$1"; _checkrun_config_dir' bash "$CHECKRUN_REPO_ROOT/lib/checkrun/common.sh")
_assert_eq "shell config: explicit HOME expression follows Python expansion" \
  "$(_canonical_test_path "$_home/real")" "$output"

# shellcheck disable=SC2088 # The literal tilde is the expansion input under test.
output=$(cd "$_td/launch" && HOME="$_home" CHECKRUN_CONFIG_DIR='~/real' \
  bash -c '. "$1"; _checkrun_config_dir' bash "$CHECKRUN_REPO_ROOT/lib/checkrun/common.sh")
_assert_eq "shell config: explicit tilde follows Python expansion" \
  "$(_canonical_test_path "$_home/real")" "$output"

output=$(cd "$_td/launch" && CONFIG_ROOT="$_td/env root" \
  CHECKRUN_CONFIG_DIR='$CONFIG_ROOT/nested' \
  bash -c '. "$1"; _checkrun_config_dir' bash "$CHECKRUN_REPO_ROOT/lib/checkrun/common.sh")
_assert_eq "shell config: explicit environment expression follows Python expansion" \
  "$(_canonical_test_path "$_td/env root/nested")" "$output"

output=$(cd "$_td/launch" && CHECKRUN_CONFIG_DIR='missing relative' \
  bash -c '. "$1"; _checkrun_config_dir' bash "$CHECKRUN_REPO_ROOT/lib/checkrun/common.sh")
_assert_eq "shell config: nonexistent relative override becomes cwd-independent" \
  "$(_canonical_test_path "$_td/launch/missing relative")" "$output"

output=$(CHECKRUN_CONFIG_DIR="$_td/launch/../home/real" \
  bash -c '. "$1"; _checkrun_config_dir' bash "$CHECKRUN_REPO_ROOT/lib/checkrun/common.sh")
_assert_eq "shell config: absolute override normalizes parent components" \
  "$(_canonical_test_path "$_home/real")" "$output"

ln -s "$_home/real" "$_td/config-link"
output=$(CHECKRUN_CONFIG_DIR="$_td/config-link" \
  bash -c '. "$1"; _checkrun_config_dir' bash "$CHECKRUN_REPO_ROOT/lib/checkrun/common.sh")
_assert_eq "shell config: absolute override resolves symlink identity" \
  "$(_canonical_test_path "$_home/real")" "$output"

output=$(CHECKRUN_CONFIG_DIR="$_td/missing-parent/../future-config" \
  bash -c '. "$1"; _checkrun_config_dir' bash "$CHECKRUN_REPO_ROOT/lib/checkrun/common.sh")
_assert_eq "shell config: absolute override normalizes a nonexistent parent" \
  "$(_canonical_test_path "$_td/future-config")" "$output"

output=$(cd "$_td/launch" && CHECKRUN_CONFIG_DIR='$(touch injected)' \
  bash -c '. "$1"; _checkrun_config_dir' bash "$CHECKRUN_REPO_ROOT/lib/checkrun/common.sh")
_assert_eq "shell config: command substitution text remains literal" \
  "$(_canonical_test_path "$_td/launch/\$(touch injected)")" "$output"
if [[ -e "$_td/launch/injected" ]]; then
  _fail "shell config: explicit override does not execute commands"
else
  _pass "shell config: explicit override does not execute commands"
fi

if output=$(env -u HOME -u CHECKRUN_CONFIG_DIR XDG_CONFIG_HOME=relative/config \
  "$CHECKRUN_REPO_ROOT/bin/autoformat" "$_td/missing.py" 2>&1); then
  rc=0
else
  rc=$?
fi
_assert_exit "direct autoformat: unresolved config root exits nonzero" 1 "$rc"
_assert_contains "direct autoformat: unresolved config root reports HOME requirement" \
  "HOME is required" "$output"

if output=$(env -u HOME -u CHECKRUN_CONFIG_DIR XDG_CONFIG_HOME=relative/config \
  "$CHECKRUN_REPO_ROOT/bin/autolint" "$_td/missing.py" 2>&1); then
  rc=0
else
  rc=$?
fi
_assert_exit "direct autolint: unresolved config root exits nonzero" 1 "$rc"
_assert_contains "direct autolint: unresolved config root reports HOME requirement" \
  "HOME is required" "$output"

python3 - "$CHECKRUN_REPO_ROOT" "$_td" "$_home" "$_xdg_config" "$_xdg_data" \
  "$_td/launch" <<'PY'
import os
import sys
from pathlib import Path

root, temp, home, xdg_config, xdg_data, launch = map(Path, sys.argv[1:])
os.environ["HOME"] = str(home)
sys.path.insert(0, str(root / "lib/checkrun"))
sys.path.insert(0, str(root / "lib/checkrun/schemas"))

import checkrun_paths as paths
import schema_policy

os.environ.pop("CHECKRUN_CONFIG_DIR", None)
os.environ.pop("CHECKRUN_SCHEMA_ASSOCIATIONS", None)
os.environ["XDG_CONFIG_HOME"] = str(xdg_config)
os.environ["XDG_DATA_HOME"] = str(xdg_data)
os.environ.pop("HOME", None)
original_home = Path.home


def unexpected_home(_cls):
    raise AssertionError("unexpected HOME lookup")


Path.home = classmethod(unexpected_home)
try:
    assert paths.config_dir() == xdg_config / "checkrun"
    assert paths.data_dir() == xdg_data
    assert schema_policy.policy_path() == xdg_config / "checkrun/associations.json"
    assert schema_policy.schema_path({}, {"schema": "settings.schema.json"}) == (
        xdg_data / "checkrun/schemas/settings.schema.json"
    )
finally:
    Path.home = original_home
    os.environ["HOME"] = str(home)

os.environ["XDG_CONFIG_HOME"] = "relative/config"
os.environ["XDG_DATA_HOME"] = "relative/data"
assert paths.config_dir() == home / ".config/checkrun"
assert paths.data_dir() == home / ".local/share"

os.chdir(launch)
os.environ["CONFIG_ROOT"] = str(temp / "env root")
for override, expected in (
    ("explicit config", launch / "explicit config"),
    ("$HOME/real", home / "real"),
    ("~/real", home / "real"),
    ("$CONFIG_ROOT/nested", temp / "env root/nested"),
    ("missing relative", launch / "missing relative"),
    (str(launch / "../home/real"), home / "real"),
    (str(temp / "config-link"), home / "real"),
    (str(temp / "missing-parent/../future-config"), temp / "future-config"),
):
    os.environ["CHECKRUN_CONFIG_DIR"] = override
    assert paths.config_dir() == expected.resolve()
os.environ["CHECKRUN_SCHEMA_ASSOCIATIONS"] = "policy/associations.json"
assert schema_policy.policy_path() == home / "policy/associations.json"
assert schema_policy.schema_path(
    {"schemaDataDir": "custom/schemas"}, {"schema": "settings.schema.json"}
) == home / "custom/schemas/settings.schema.json"
PY
_assert_exit "Python policy: config, data, and explicit precedence agree" 0 "$?"

mkdir -p "$_xdg_config/checkrun" "$_td/project"
printf '*target.py\n' >"$_xdg_config/checkrun/ignore"
printf 'value = 1\n' >"$_td/project/target.py"
output=$(HOME="$_home" XDG_CONFIG_HOME="$_xdg_config" CHECKRUN_CONFIG_DIR='' \
  "$CHECKRUN_REPO_ROOT/bin/checkrun" explain --json "$_td/project/target.py" 2>&1)
_assert_contains "CLI policy: direct Python dispatch receives shell-resolved XDG config" \
  '"ignored":true' "$output"

_test_summary
