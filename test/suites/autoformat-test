func main() {
x:=1
_=x
}
EOF
  "$AUTOFORMAT" "$_td/test.go"
  _assert_contains "go: gofumpt formats" "	x := 1" "$(cat "$_td/test.go")"
else
  echo "  SKIP: go (gofumpt not installed)"
fi

