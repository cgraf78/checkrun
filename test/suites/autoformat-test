x=1
EOF
"$AUTOFORMAT" "$_td/test.toml"
_assert_contains "toml: taplo formats" 'x = 1' "$(cat "$_td/test.toml")"

cat >"$_td/test.rs" <<'EOF'
fn main( ){ }
EOF
"$AUTOFORMAT" "$_td/test.rs"
_assert_eq "rust: rustfmt formats" 'fn main() {}' "$(cat "$_td/test.rs")"

# yamlfmt: reformats spacing and quoting around mappings.
cat >"$_td/test.yaml" <<'EOF'
a:  1
b:   [1,2,3]
EOF
"$AUTOFORMAT" "$_td/test.yaml"
_assert_contains "yaml: yamlfmt formats (single-space after colon)" "a: 1" "$(cat "$_td/test.yaml")"

# Go: gofumpt formats (goimports runs first if available)
if command -v gofumpt &>/dev/null; then
  cat >"$_td/test.go" <<'EOF'
