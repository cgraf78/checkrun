#!/usr/bin/env bash
# autoformat-test — unit tests for the autoformat script.
#
# Tests formatting dispatch, config file discovery, fallback defaults,
# shebang detection, and no-op behavior for unsupported/missing files.
#
# Usage: autoformat-test

set -o pipefail
export NO_COLOR=1

# Formatter/linter dev tooling is expected to come from a mise toolset, so seed
# the shim dir explicitly for direct test runs. CI sets MISE_GLOBAL_CONFIG_FILE
# to the repo-local manifest; local runs usually inherit the user's superset.
# On macOS, brew binaries are signed and must take priority over
# unsigned mise downloads that macOS Gatekeeper kills.
[ -d "$HOME/.local/share/mise/shims" ] &&
  PATH="$HOME/.local/share/mise/shims:$PATH"
[ -d "/opt/homebrew/bin" ] &&
  PATH="/opt/homebrew/bin:$PATH"
: "${MISE_GLOBAL_CONFIG_FILE:=$HOME/.config/mise/config.toml}"
export MISE_GLOBAL_CONFIG_FILE

CHECKRUN_TEST_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd -P)"
CHECKRUN_REPO_ROOT="$(cd -- "$CHECKRUN_TEST_DIR/.." && pwd -P)"

# shellcheck source=../helpers.sh
. "$CHECKRUN_TEST_DIR/helpers.sh"

_require_compatible_libc "autoformat-test"

AUTOFORMAT="$CHECKRUN_REPO_ROOT/bin/autoformat"
CHECKRUN="$CHECKRUN_REPO_ROOT/bin/checkrun"
export CHECKRUN_AUTOFORMAT_DIR
CHECKRUN_AUTOFORMAT_DIR=$(_checkrun_default_autoformat_dir)

# ---------------------------------------------------------------------------
# Tests: public shell API
# ---------------------------------------------------------------------------

echo "=== Public shell API ==="

shell_api_output=$(
  CHECKRUN_REPO_ROOT="$CHECKRUN_REPO_ROOT" bash --noprofile --norc -c '
    source "$CHECKRUN_REPO_ROOT/share/checkrun/shell.sh"
    printf "loaded=%s\n" "${CHECKRUN_SHELL_LOADED:-0}"
  '
)
_assert_contains "shell api: loader is sourceable" \
  "loaded=1" "$shell_api_output"

# ---------------------------------------------------------------------------
# Tests: CLI help
# ---------------------------------------------------------------------------

echo "=== CLI help ==="

_help_bin=$(_mock_bin)
ln -s "$(command -v bash)" "$_help_bin/bash"
ln -s "$(command -v readlink)" "$_help_bin/readlink"

set +e
output=$(PATH="$_help_bin" "$AUTOFORMAT" --help 2>&1)
rc=$?
_assert_exit "help: --help exits 0" 0 "$rc"
_assert_contains "help: --help shows usage" "Usage: autoformat" "$output"
_assert_contains "help: --help lists supported file types" "Supported file types:" "$output"
_assert_colon_list_values_aligned "help: --help aligns supported file list" \
  "$output" "Supported file types:"
_assert_contains "help: --help aligns build category" "Build:     .bzl" "$output"
_assert_contains "help: --help lists cmake files" "CMakeLists.txt, .cmake" "$output"
_assert_contains "help: --help aligns c/c++ category" "C/C++:     .c" "$output"
_assert_contains "help: --help aligns container category" "Container: Dockerfile" "$output"
_assert_contains "help: --help uses docs/text category" "Docs/text: .md" "$output"
_assert_contains "help: --help lists shell files" ".sh, .bash, .zsh" "$output"
_assert_contains "help: --help lists envrc files" ".envrc" "$output"
_assert_contains "help: --help lists config files" ".toml, .yaml, .yml" "$output"
_assert_contains "help: --help lists java files" ".java" "$output"
_assert_contains "help: --help lists php files" ".php" "$output"
_assert_contains "help: --help lists ruby files" ".rb" "$output"
_assert_contains "help: --help lists css files" ".css" "$output"
_assert_contains "help: --help lists special basenames" "Dockerfile, Containerfile" "$output"
_assert_not_contains "help: --help has no other bucket" "Other:" "$output"

set +e
output=$(PATH="$_help_bin" "$AUTOFORMAT" -h 2>&1)
rc=$?
_assert_exit "help: -h exits 0" 0 "$rc"
_assert_contains "help: -h shows usage" "Usage: autoformat" "$output"
_assert_contains "help: -h lists supported file types" "Supported file types:" "$output"
_assert_not_contains "help: -h has no other bucket" "Other:" "$output"

symlink_bin=$(_tmpdir)/bin
mkdir -p "$symlink_bin"
ln -s "$AUTOFORMAT" "$symlink_bin/autoformat"
ln -s "$CHECKRUN" "$symlink_bin/checkrun"

set +e
output=$(PATH="$_help_bin" "$symlink_bin/autoformat" --help 2>&1)
rc=$?
_assert_exit "help: symlinked autoformat resolves dependency library" 0 "$rc"
_assert_contains "help: symlinked autoformat shows usage" "Usage: autoformat" "$output"

set +e
output=$(PATH="$symlink_bin:$_help_bin" "$symlink_bin/checkrun" format --help 2>&1)
rc=$?
_assert_exit "help: symlinked checkrun dispatch resolves autoformat" 0 "$rc"
_assert_contains "help: symlinked checkrun format shows usage" "Usage: autoformat" "$output"

