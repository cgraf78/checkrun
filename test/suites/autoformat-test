# Starlark: buildifier formats (BUCK basename dispatch)
if command -v buildifier &>/dev/null; then
  cat >"$_td/BUCK" <<'EOF'
load("@rules","rule")
rule(name="a",srcs=["b"])
EOF
  "$AUTOFORMAT" "$_td/BUCK"
  _assert_contains "BUCK: buildifier formats" 'name = "a"' "$(cat "$_td/BUCK")"

  cat >"$_td/BUILD" <<'EOF'
load("@rules","rule")
rule(name="a",srcs=["b"])
EOF
  "$AUTOFORMAT" "$_td/BUILD"
  _assert_contains "BUILD: buildifier formats" 'name = "a"' "$(cat "$_td/BUILD")"
else
  echo "  SKIP: BUCK/BUILD (buildifier not installed)"
fi

# CMake: cmake-format dispatch and fallback config routing. Uses a
# mock because cmake-format is optional on the host running the tests.
_cmakefmt_mock=$(_mock_bin)
cat >"$_cmakefmt_mock/cmake-format" <<'EOF'
#!/usr/bin/env bash
echo "MOCK-CMAKE-FORMAT-ARGS: $*"
exit 0
EOF
chmod +x "$_cmakefmt_mock/cmake-format"

_cmakefmt_cfg=$(_tmpdir)
: >"$_cmakefmt_cfg/cmake-format.py"
cat >"$_td/CMakeLists.txt" <<'EOF'
add_executable(app main.cpp)
EOF
set +e
output=$(CHECKRUN_AUTOFORMAT_DIR="$_cmakefmt_cfg" PATH="$_cmakefmt_mock:$PATH" "$AUTOFORMAT" "$_td/CMakeLists.txt" 2>&1)
rc=$?
set -e
_assert_exit "cmake: CMakeLists.txt exits 0" 0 "$rc"
_assert_contains "cmake: CMakeLists.txt dispatches to cmake-format" \
  "MOCK-CMAKE-FORMAT-ARGS:" "$output"
_assert_contains "cmake: fallback config passed via --config-files" \
  "--config-files $_cmakefmt_cfg/cmake-format.py" "$output"

echo 'include(foo)' >"$_td/module.cmake"
set +e
output=$(CHECKRUN_AUTOFORMAT_DIR="$_cmakefmt_cfg" PATH="$_cmakefmt_mock:$PATH" "$AUTOFORMAT" "$_td/module.cmake" 2>&1)
rc=$?
set -e
_assert_exit "cmake: .cmake exits 0" 0 "$rc"
_assert_contains "cmake: .cmake dispatches to cmake-format" \
  "MOCK-CMAKE-FORMAT-ARGS:" "$output"

# rumdl --fix: auto-fixes rule violations. MD019 (multiple spaces
# after the heading hash) has a reliable cross-version fix.
printf '#  Title\n' >"$_td/test.md"
"$AUTOFORMAT" "$_td/test.md"
_assert_contains "md: rumdl --fix normalizes heading spacing" "# Title" "$(cat "$_td/test.md")"

