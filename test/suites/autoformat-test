_assert_exit "ruby: rubocop formatter exits 0" 0 "$rc"
_assert_contains "ruby: rubocop formatter runs" "MOCK-RUBOCOP-FMT-ARGS:" "$output"
_assert_contains "ruby: rubocop formatter uses layout-only autocorrect" \
  "--autocorrect --only Layout" "$output"
_assert_contains "ruby: fallback rubocop.yml passed via --config" \
  "--config $_ruby_cfg/rubocop.yml" "$output"

