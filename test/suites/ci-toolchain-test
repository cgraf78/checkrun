#!/usr/bin/env bash
set -euo pipefail

test_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd -P)"
repo_root="$(cd -- "$test_dir/../.." && pwd -P)"

python3 "$repo_root/.github/scripts/verify_mise_lock.py" \
  "$repo_root/.github/mise/checkrun-ci.toml" \
  "$repo_root/.github/mise/mise.lock"

python3 - "$repo_root/.github/scripts/verify_mise_lock.py" <<'PY'
from __future__ import annotations

import importlib.util
import sys
from copy import deepcopy
from pathlib import Path

script = Path(sys.argv[1])
spec = importlib.util.spec_from_file_location("verify_mise_lock", script)
if spec is None or spec.loader is None:
    raise RuntimeError(f"cannot load {script}")
module = importlib.util.module_from_spec(spec)
spec.loader.exec_module(module)

config = {
    "settings": {"lockfile_platforms": ["linux-x64"]},
    "tools": {"aqua:owner/tool": "latest"},
}
entry = {
    "version": "1.2.3",
    "backend": "aqua:owner/tool",
    "platforms.linux-x64": {"url": "https://example.test/tool"},
}
lock = {"tools": {"aqua:owner/tool": [entry]}}


def assert_error(expected: str, candidate_config: dict, candidate_lock: dict) -> None:
    """Require one focused fixture to produce its expected diagnostic."""
    errors = module.verify(candidate_config, candidate_lock)
    if expected not in errors:
        raise AssertionError(f"missing {expected!r} in {errors!r}")


if module.verify(config, lock):
    raise AssertionError("valid fixture was rejected")

assert_error("missing lock entry: aqua:owner/tool", config, {"tools": {}})

stale = deepcopy(lock)
stale["tools"]["aqua:owner/stale"] = [deepcopy(entry)]
assert_error("stale lock entry: aqua:owner/stale", config, stale)

missing_platform = deepcopy(lock)
del missing_platform["tools"]["aqua:owner/tool"][0]["platforms.linux-x64"]
assert_error(
    "aqua:owner/tool: missing platform linux-x64", config, missing_platform
)

missing_url = deepcopy(lock)
missing_url["tools"]["aqua:owner/tool"][0]["platforms.linux-x64"] = {}
assert_error("aqua:owner/tool: linux-x64 has no locked URL", config, missing_url)

duplicate = deepcopy(lock)
duplicate["tools"]["aqua:owner/tool"].append(deepcopy(entry))
assert_error("aqua:owner/tool: expected exactly one locked version", config, duplicate)
PY

printf 'ci-toolchain-test: ok\n'
