#!/usr/bin/env bash
# checkrun-cli-test — unit tests for the top-level checkrun command.
#
# Usage: checkrun-cli-test

set -o pipefail
export NO_COLOR=1

CHECKRUN_TEST_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd -P)"
CHECKRUN_REPO_ROOT="$(cd -- "$CHECKRUN_TEST_DIR/.." && pwd -P)"

# shellcheck source=../helpers.sh
. "$CHECKRUN_TEST_DIR/helpers.sh"

_require_compatible_libc "checkrun-cli-test"

CHECKRUN="$CHECKRUN_REPO_ROOT/bin/checkrun"

echo "=== checkrun: top-level help ==="

output=$("$CHECKRUN" --help 2>&1)
rc=$?
_assert_exit "help: --help exits 0" 0 "$rc"
_assert_contains "help: lists capabilities command" "capabilities" "$output"
_assert_contains "help: lists registry command" "registry" "$output"
_assert_contains "help: lists plan command" "plan" "$output"
_assert_contains "help: lists explain command" "explain" "$output"
_assert_contains "help: lists schema command" "schema" "$output"
_assert_contains "help: lists check alias" "check     alias for lint" "$output"

output=$("$CHECKRUN" check --help 2>&1)
rc=$?
_assert_exit "check alias: --help exits 0" 0 "$rc"
_assert_contains "check alias: dispatches to autolint" "Usage: autolint" "$output"

output=$("$CHECKRUN" schema --help 2>&1)
rc=$?
_assert_exit "schema help: --help exits 0" 0 "$rc"
_assert_contains "schema help: lists refresh command" "refresh" "$output"

output=$("$CHECKRUN" schema refresh --help 2>&1)
rc=$?
_assert_exit "schema refresh help: --help exits 0" 0 "$rc"
_assert_contains "schema refresh help: lists check mode" "--check" "$output"
_assert_contains "schema refresh help: lists association filter" "--association" "$output"

_schema_python_bin=$(_mock_bin)
_schema_python_marker="$_schema_python_bin/selected"
cat >"$_schema_python_bin/python3-no-tomllib" <<EOF
#!/usr/bin/env bash
if [[ "\${1:-}" == "-c" && "\${2:-}" == "import tomllib" ]]; then
  exit 1
fi
if [[ "\${1:-}" != "-c" ]]; then
  touch "$_schema_python_marker"
fi
exec "$(command -v python3)" "\$@"
EOF
chmod +x "$_schema_python_bin/python3-no-tomllib"
output=$(CHECKRUN_PYTHON="$_schema_python_bin/python3-no-tomllib" "$CHECKRUN" schema refresh --help 2>&1)
rc=$?
_assert_exit "schema refresh: does not require registry tomllib floor" 0 "$rc"
_assert_file_exists "schema refresh: uses python without tomllib probe" "$_schema_python_marker"
_assert_contains "schema refresh: selected python still shows help" "--check" "$output"

set +e
output=$("$CHECKRUN" schema missing 2>&1)
rc=$?
set -e
_assert_exit "schema: unknown subcommand exits usage-style non-zero" 2 "$rc"
_assert_contains "schema: unknown subcommand is reported" "unknown command: missing" "$output"

echo "=== checkrun: capabilities ==="

output=$("$CHECKRUN" capabilities --json 2>&1)
rc=$?
_assert_exit "capabilities: --json exits 0" 0 "$rc"
printf '%s\n' "$output" | python3 -c '
import json
import sys

data = json.load(sys.stdin)
assert data["version"] == 2
assert "sley" not in data
assert data["editorLanguageIds"]["vscode"]["sh"] == ["shellscript"]
assert "python" in data["filetypes"]["format"]
assert "systemd" in data["filetypes"]["lint"]
assert data["filetypes"]["custom"]["filename"]["Dockerfile"] == "dockerfile"
'
_assert_exit "capabilities: emits supported filetype metadata" 0 "$?"

_minimal_path_bin=$(_mock_bin)
ln -s "$(command -v bash)" "$_minimal_path_bin/bash"
set +e
output=$(PATH="$_minimal_path_bin" "$CHECKRUN" capabilities --json 2>&1)
rc=$?
set -e
_assert_exit "capabilities: minimal PATH still finds python" 0 "$rc"
printf '%s\n' "$output" | python3 -c '
import json
import sys

data = json.load(sys.stdin)
assert data["version"] == 2
assert "python" in data["filetypes"]["format"]
'
_assert_exit "capabilities: minimal PATH emits JSON" 0 "$?"

_bad_python_bin=$(_mock_bin)
ln -s "$(command -v bash)" "$_bad_python_bin/bash"
cat >"$_bad_python_bin/python3" <<'EOF'
#!/usr/bin/env bash
echo "bad python selected" >&2
exit 1
EOF
chmod +x "$_bad_python_bin/python3"
set +e
output=$(PATH="$_bad_python_bin" "$CHECKRUN" capabilities --json 2>&1)
rc=$?
set -e
_assert_exit "capabilities: unusable PATH python is skipped" 0 "$rc"
_assert_not_contains "capabilities: unusable PATH python does not run" "bad python selected" "$output"

output=$("$CHECKRUN" registry --json 2>&1)
rc=$?
_assert_exit "registry: --json exits 0" 0 "$rc"
printf '%s\n' "$output" | python3 -c '
import json
import sys

data = json.load(sys.stdin)
assert data["version"] == 1
assert "sley" not in data
assert any(item["id"] == "web" for item in data["selectors"])
'
_assert_exit "registry: emits raw registry metadata" 0 "$?"

echo "=== checkrun: explain ==="

_td=$(_tmpdir)
_cfg="$_td/cfg"
_policy="$_td/associations.json"
mkdir -p "$_cfg" "$_td/.config/example"
cat >"$_cfg/format-ignore" <<EOF
*/skip.py
EOF
cat >"$_cfg/tool-ignore" <<EOF
*/biome.json
EOF
cat >"$_policy" <<'JSON'
{
  "version": 1,
  "associations": [
    {
      "name": "Example config",
      "format": "json",
      "schema": "example.schema.json",
      "matches": [".config/example/*.json"],
      "enforce": true
    }
  ]
}
JSON
mkdir -p "$_td/.github/workflows"
touch \
  "$_td/keep.py" \
  "$_td/skip.py" \
  "$_td/biome.json" \
  "$_td/plain.yaml" \
  "$_td/.github/workflows/build.yml" \
  "$_td/.config/example/settings.json"

output=$(CHECKRUN_CONFIG_DIR="$_cfg" "$CHECKRUN" explain --json "$_td/keep.py" 2>&1)
rc=$?
_assert_exit "explain: python exits 0" 0 "$rc"
printf '%s\n' "$output" | python3 -c '
import json
import sys

item = json.load(sys.stdin)[0]
assert item["filetype"] == "python"
assert item["format"]["tools"][0]["tool"] == "ruff"
assert item["lint"]["tools"][0]["tool"] == "ruff"
assert item["format"]["ignored"] is False
'
_assert_exit "explain: reports python formatter and linter" 0 "$?"

output=$(CHECKRUN_CONFIG_DIR="$_cfg" "$CHECKRUN" explain --json "$_td/skip.py" 2>&1)
rc=$?
_assert_exit "explain: ignored format exits 0" 0 "$rc"
printf '%s\n' "$output" | python3 -c '
import json
import sys

item = json.load(sys.stdin)[0]
assert item["format"]["ignored"] is True
assert item["format"]["ignore"]["pattern"] == "*/skip.py"
assert item["lint"]["tools"][0]["tool"] == "ruff"
'
_assert_exit "explain: reports phase-specific format ignore" 0 "$?"

output=$(CHECKRUN_CONFIG_DIR="$_cfg" "$CHECKRUN" explain --json "$_td/biome.json" 2>&1)
rc=$?
_assert_exit "explain: tool-ignore exits 0" 0 "$rc"
printf '%s\n' "$output" | python3 -c '
import json
import sys

item = json.load(sys.stdin)[0]
assert item["filetype"] == "json"
assert item["lint"]["phases"]["tool"]["ignored"] is True
assert item["lint"]["tools"] == []
assert [step["reason"] for step in item["lint"]["skipped"] if step["tool"] == "biome"] == ["phase-ignore"]
	'
_assert_exit "explain: reports backend tool ignore and skipped step separately" 0 "$?"

output=$(CHECKRUN_CONFIG_DIR="$_cfg" "$CHECKRUN" explain --json "$_td/plain.yaml" 2>&1)
rc=$?
_assert_exit "explain: generic yaml exits 0" 0 "$rc"
printf '%s\n' "$output" | python3 -c '
import json
import sys

item = json.load(sys.stdin)[0]
assert item["filetype"] == "yaml"
assert [tool["tool"] for tool in item["format"]["tools"]] == ["yamlfmt"]
assert item["lint"]["tools"] == []
assert [step["tool"] for step in item["lint"]["skipped"]] == ["actionlint", "zizmor"]
assert all(step["reason"] == "path-pattern" for step in item["lint"]["skipped"])
	'
_assert_exit "explain: generic yaml explains skipped workflow-only linters" 0 "$?"

output=$(CHECKRUN_CONFIG_DIR="$_cfg" "$CHECKRUN" explain --json "$_td/.github/workflows/build.yml" 2>&1)
rc=$?
_assert_exit "explain: workflow yaml exits 0" 0 "$rc"
printf '%s\n' "$output" | python3 -c '
import json
import sys

item = json.load(sys.stdin)[0]
assert item["filetype"] == "yaml"
assert [tool["tool"] for tool in item["lint"]["tools"]] == ["actionlint", "zizmor"]
'
_assert_exit "explain: workflow yaml includes workflow-only linters" 0 "$?"

output=$(CHECKRUN_SCHEMA_ASSOCIATIONS="$_policy" "$CHECKRUN" explain --json "$_td/.config/example/settings.json" 2>&1)
rc=$?
_assert_exit "explain: schema association exits 0" 0 "$rc"
printf '%s\n' "$output" | python3 -c '
import json
import sys

item = json.load(sys.stdin)[0]
assert item["lint"]["schemas"][0]["name"] == "Example config"
assert item["lint"]["schemas"][0]["enforce"] is True
'
_assert_exit "explain: reports matching schema association" 0 "$?"

echo "=== checkrun: plan ==="

output=$(CHECKRUN_CONFIG_DIR="$_cfg" "$CHECKRUN" plan --json --phase lint "$_td/keep.py" 2>&1)
rc=$?
_assert_exit "plan: lint phase exits 0" 0 "$rc"
printf '%s\n' "$output" | python3 -c '
import json
import sys

data = json.load(sys.stdin)
assert data["version"] == 1
item = data["files"][0]
assert "format" not in item
assert item["filetype"] == "python"
steps = item["lint"]["steps"]
assert [step["adapter"] for step in steps[:2]] == ["typos", "schema-lint"]
assert steps[-1]["adapter"] == "ruff-lint"
'
_assert_exit "plan: lint phase includes registry-selected steps" 0 "$?"

_sc_cfg=$(_tmpdir)
_sc_repo=$(_tmpdir)
cat >"$_sc_cfg/shellcheckrc" <<'EOF'
disable=SC1091
EOF
touch "$_sc_repo/.shellcheckrc"
cat >"$_sc_repo/script.sh" <<'EOF'
#!/bin/bash
echo ok
EOF
output=$(CHECKRUN_CONFIG_DIR="$_sc_cfg" "$CHECKRUN" plan --json --phase lint "$_sc_repo/script.sh" 2>&1)
rc=$?
_assert_exit "plan: shellcheck project config exits 0" 0 "$rc"
printf '%s\n' "$output" | python3 -c '
import json
import sys

item = json.load(sys.stdin)["files"][0]
shellcheck = [step for step in item["lint"]["steps"] if step["adapter"] == "shellcheck"][0]
assert shellcheck["config"]["source"] == "project"
assert shellcheck["config"]["path"].endswith("/.shellcheckrc")
'
_assert_exit "plan: shellcheck project config suppresses fallback" 0 "$?"

output=$(CHECKRUN_CONFIG_DIR="$_cfg" "$CHECKRUN" plan --json --phase format "$_td/keep.py" 2>&1)
rc=$?
_assert_exit "plan: format phase exits 0" 0 "$rc"
printf '%s\n' "$output" | python3 -c '
import json
import sys

data = json.load(sys.stdin)
item = data["files"][0]
assert "lint" not in item
assert item["format"]["steps"][0]["adapter"] == "ruff-format"
'
_assert_exit "plan: format phase includes formatter step" 0 "$?"

output=$(CHECKRUN_CONFIG_DIR="$_cfg" "$CHECKRUN" plan --json "$_td/keep.py" 2>&1)
rc=$?
_assert_exit "plan: omitted phase exits 0" 0 "$rc"
printf '%s\n' "$output" | python3 -c '
import json
import sys

item = json.load(sys.stdin)["files"][0]
assert "format" in item
assert "lint" in item
'
_assert_exit "plan: omitted phase includes all phases" 0 "$?"

output=$(CHECKRUN_CONFIG_DIR="$_cfg" "$CHECKRUN" plan --json --phase lint "$_td/plain.yaml" 2>&1)
rc=$?
_assert_exit "plan: generic yaml exits 0" 0 "$rc"
printf '%s\n' "$output" | python3 -c '
import json
import sys

steps = json.load(sys.stdin)["files"][0]["lint"]["steps"]
assert [step["adapter"] for step in steps] == ["typos", "schema-lint"]
'
_assert_exit "plan: generic yaml omits workflow-only linters" 0 "$?"
printf '%s\n' "$output" | python3 -c '
import json
import sys

skipped = json.load(sys.stdin)["files"][0]["lint"]["skipped"]
assert [step["adapter"] for step in skipped] == ["actionlint", "zizmor"]
assert all(step["reason"] == "path-pattern" for step in skipped)
'
_assert_exit "plan: generic yaml explains workflow-only skips" 0 "$?"

output=$(CHECKRUN_CONFIG_DIR="$_cfg" "$CHECKRUN" plan --json --phase lint "$_td/.github/workflows/build.yml" 2>&1)
rc=$?
_assert_exit "plan: workflow yaml exits 0" 0 "$rc"
printf '%s\n' "$output" | python3 -c '
import json
import sys

steps = json.load(sys.stdin)["files"][0]["lint"]["steps"]
assert [step["adapter"] for step in steps] == ["typos", "schema-lint", "actionlint", "zizmor"]
'
_assert_exit "plan: workflow yaml includes scoped linters" 0 "$?"

missing_registry="$_td/missing-registry.json"
set +e
output=$(CHECKRUN_REGISTRY="$missing_registry" "$CHECKRUN" plan --json --phase lint "$_td/keep.py" 2>&1)
rc=$?
set -e
_assert_exit "plan: missing registry exits non-zero" 2 "$rc"
_assert_contains "plan: missing registry reports error" "registry file not found" "$output"

_test_summary
