for relative, (expected_format, expected_lint) in matrix.items():
    target = tmp / "matrix" / relative
    target.parent.mkdir(parents=True, exist_ok=True)
    target.write_text("", encoding="utf-8")
    format_steps = registry_mod.plan(registry, [str(target)], "format")["files"][0]["format"]["steps"]
    lint_steps = registry_mod.plan(registry, [str(target)], "lint")["files"][0]["lint"]["steps"]
    assert [step["adapter"] for step in format_steps] == expected_format, relative
    assert [step["adapter"] for step in lint_steps] == expected_lint, relative

