    "schema.proto": (["buf-format"], ["typos", "schema-lint", "buf-lint"]),
    "envrc-prod": (["shfmt"], ["typos", "schema-lint", "shellcheck"]),
    "agent-hook-pre-bash-work": (["shfmt"], ["typos", "schema-lint", "shellcheck"]),
    "envrc-prod.txt": ([], ["typos", "schema-lint"]),
    "agent-hook-pre-bash-work.py": (["ruff-format"], ["typos", "schema-lint", "ruff-lint"]),
