python3 - "$CHECKRUN_REPO_ROOT" "$REGISTRY" "$_td/unknown-dispatch.sh" <<'PY'
import importlib.util
import sys
from pathlib import Path

root = Path(sys.argv[1])
registry_path = Path(sys.argv[2])
dispatch_path = Path(sys.argv[3])

# The production shell files should never contain an unknown dispatch arm, so use
# a tiny fixture to exercise the invariant directly instead of weakening the
# check by making it depend on today's concrete adapter list.
dispatch_path.write_text(
    """
_format_dispatch() {
  local adapter="$1"
  case "$adapter" in
    ruff-format) _format_ruff "$file" "$dir" "$config_source" "$config_path" ;;
  esac
}

_run_lint_step() {
  local adapter="$1"
  case "$adapter" in
    missing-lint) _lint_ruff "$file" "$dir" "$config_source" "$config_path" ;;
  esac
}
""",
    encoding="utf-8",
)

spec = importlib.util.spec_from_file_location(
    "checkrun_registry", root / "lib/checkrun/registry.py"
)
registry_mod = importlib.util.module_from_spec(spec)
assert spec.loader is not None
spec.loader.exec_module(registry_mod)
registry_mod._SHELL_DISPATCH = {
    "format": (dispatch_path, "_format_dispatch()"),
    "lint": (dispatch_path, "_run_lint_step()"),
}

try:
    registry_mod.load_registry(registry_path)
except registry_mod.RegistryError as error:
    assert "unknown registry adapters" in str(error), str(error)
else:
    raise AssertionError("unknown shell dispatch adapter was accepted")
PY
_assert_exit "registry: unknown shell dispatch adapter is rejected" 0 "$?"

