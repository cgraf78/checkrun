import importlib.util
import json
import sys
from pathlib import Path

root = Path(sys.argv[1])
registry_path = Path(sys.argv[2])
tmp = Path(sys.argv[3])

spec = importlib.util.spec_from_file_location(
    "checkrun_registry", root / "lib/checkrun/registry.py"
)
registry_mod = importlib.util.module_from_spec(spec)
assert spec.loader is not None
spec.loader.exec_module(registry_mod)

for key, value in {
    "extensions": ["py"],
    "filenames": ["script.py"],
    "patterns": ["*.py"],
}.items():
    data = json.loads(registry_path.read_text(encoding="utf-8"))
    data["selectors"][0][key] = value
    path = tmp / f"selector-{key}.json"
    path.write_text(json.dumps(data), encoding="utf-8")
    try:
        registry_mod.load_registry(path)
    except registry_mod.RegistryError as error:
        assert "unknown key" in str(error), str(error)
    else:
        raise AssertionError(f"selector-local {key} matcher was accepted")
