{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://cgraf78.github.io/checkrun/schemas/associations.schema.json",
  "title": "Checkrun schema association policy",
  "type": "object",
  "required": ["version", "associations"],
  "additionalProperties": false,
  "properties": {
    "version": {
      "type": "integer",
      "const": 1
    },
    "schemaDataDir": {
      "type": "string",
      "minLength": 1,
      "not": { "pattern": "[\\u0000-\\u001F\\u007F]" }
    },
    "associations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "format", "matches", "enforce"],
        "additionalProperties": false,
        "allOf": [
          {
            "anyOf": [{ "required": ["schema"] }, { "required": ["editorSource"] }]
          },
          {
            "if": {
              "properties": {
                "enforce": { "const": true }
              },
              "required": ["enforce"]
            },
            "then": {
              "required": ["schema"]
            }
          },
          {
            "if": {
              "required": ["source"]
            },
            "then": {
              "required": ["schema"]
            }
          }
        ],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1,
            "not": { "pattern": "[\\u0000-\\u001F\\u007F]" }
          },
          "format": {
            "type": "string",
            "enum": ["json", "yaml", "toml"]
          },
          "schema": {
            "type": "string",
            "minLength": 1,
            "not": { "pattern": "[\\u0000-\\u001F\\u007F]" }
          },
          "dependency": {
            "type": "string",
            "minLength": 1,
            "not": { "pattern": "[\\u0000-\\u001F\\u007F]" }
          },
          "source": {
            "type": "string",
            "minLength": 1,
            "not": { "pattern": "[\\u0000-\\u001F\\u007F]" }
          },
          "editorSource": {
            "type": "string",
            "minLength": 1,
            "not": { "pattern": "[\\u0000-\\u001F\\u007F]" }
          },
          "matches": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1,
              "not": { "pattern": "[\\u0000-\\u001F\\u007F]" }
            }
          },
          "enforce": {
            "type": "boolean"
          },
          "note": {
            "type": "string",
            "minLength": 1,
            "not": { "pattern": "[\\u0000-\\u001F\\u007F]" }
          }
        }
      }
    }
  }
}
